# =============================
# Facebook Messenger
# =============================
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FB_VERIFY_TOKEN=your_webhook_verify_token_choose_any_string
FB_APP_SECRET=your_facebook_app_secret

# =============================
# Telegram Bot
# =============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_LEAD_CHAT_ID=your_telegram_chat_id

# =============================
# Anthropic (Claude) API
# =============================
ANTHROPIC_API_KEY=your_anthropic_api_key

# =============================
# Supabase
# =============================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# =============================
# Google Calendar
# =============================
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com
# Path to Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google_service_account.json

# =============================
# Google Sheets
# =============================
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_NAME=Appointments

# =============================
# Clinic Info
# =============================
CLINIC_NAME=Шүдний Эмнэлэг
CLINIC_PHONE=+976-9999-9999
CLINIC_ADDRESS=Улаанбаатар, ...
CLINIC_WORKING_HOURS_START=09:00
CLINIC_WORKING_HOURS_END=18:00
CLINIC_SLOT_DURATION_MINUTES=30

# =============================
# App
# =============================
PORT=8000
